---
import type { MarkdownHeading } from 'astro'
import type { CollectionEntry } from 'astro:content'

// Plugin styles
import 'katex/dist/katex.min.css'

import config from 'virtual:config'

import { MediumZoom } from 'astro-pure/advanced'
import { ArticleBottom, TOC } from 'astro-pure/components/pages'
import PageLayout from '@/layouts/ContentLayout.astro'
import { localizedPath, type SiteLocale } from '@/i18n/ui'
import LocalizedHero from '@/components/blog/LocalizedHero.astro'
import LocalizedCopyright from '@/components/blog/LocalizedCopyright.astro'
import CommentsSection from '@/components/blog/CommentsSection.astro'
import { PageInfo } from '@/components/waline'

interface Props {
  post: CollectionEntry<'blog'>
  posts: CollectionEntry<'blog'>[]
  headings: MarkdownHeading[]
  remarkPluginFrontmatter: Record<string, unknown>
}

const {
  post: { id, data },
  posts,
  headings,
  remarkPluginFrontmatter
} = Astro.props

const { description, draft: isDraft, heroImage, publishDate, title, updatedDate } = data

const socialImage = heroImage
  ? typeof heroImage.src === 'string'
    ? heroImage.src
    : heroImage.src.src
  : config.socialCard
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString()
const primaryColor = 'hsl(var(--primary) / var(--un-text-opacity))'
const locale = data.locale as SiteLocale
---

<PageLayout
  meta={{ articleDate, description, ogImage: socialImage, title }}
  highlightColor={primaryColor}
  back={localizedPath('/blog', locale)}
  {locale}
  hasSidebar={headings.length > 0}
>
  {!!headings.length && <TOC {headings} slot='sidebar' />}

  <Fragment slot='header'>
    <LocalizedHero {data} {remarkPluginFrontmatter} {locale} />
    {!isDraft && <PageInfo comment class='mt-2 italic' />}
  </Fragment>

  <slot />

  <Fragment slot='bottom'>
    {/* Copyright */}
    <LocalizedCopyright {data} {locale} />
    {/* Article recommend */}
    <ArticleBottom collections={posts} {id} class='mt-3 sm:mt-6' />
    <CommentsSection {locale} />
  </Fragment>

  <slot name='bottom-sidebar' slot='bottom-sidebar' />
</PageLayout>

{config.integ.mediumZoom.enable && <MediumZoom />}
