---
import { ThemeProvider } from 'astro-pure/components/basic'
import type { SiteMeta } from 'astro-pure/types'
import BaseHead from '@/components/BaseHead.astro'
import SiteHeader from '@/components/navigation/SiteHeader.astro'
import SiteFooter from '@/components/navigation/SiteFooter.astro'
import config from '@/site-config'
import type { SiteLocale } from '@/i18n/ui'

// Import the global.css file here so that it is included on
// all pages through the use of the <BaseLayout /> component.
import '@/assets/styles/global.css'
import '@/assets/styles/app.css'

interface Props {
  meta: SiteMeta
  highlightColor?: string
  locale?: SiteLocale
}

const {
  meta: { articleDate, description = config.description, ogImage, title },
  highlightColor,
  locale = 'en-US',
  ...props
} = Astro.props

const canonicalPath = Astro.url.pathname.replace(/^\/en(?=\/|$)/, '') || '/'
const detailMatch = canonicalPath.match(/^\/(blog|projects|notes)\/[^/]+/)
const searchSection = detailMatch?.[1] ?? 'pages'
const searchIndexable =
  canonicalPath === '/' ||
  canonicalPath === '/about' ||
  canonicalPath === '/contact' ||
  Boolean(detailMatch)
---

<html lang={locale}>
  <head>
    <BaseHead {articleDate} {description} {ogImage} {title} {locale} />
    <ThemeProvider />
    <script is:inline>
      const storedLocale = localStorage.getItem('locale')
      const savedLocale = storedLocale === 'zh-CN' || storedLocale === 'en-US' ? storedLocale : 'en-US'
      if (!storedLocale) localStorage.setItem('locale', savedLocale)

      const isEnglishPath = location.pathname === '/en' || location.pathname.startsWith('/en/')
      const pathWithoutLocale = isEnglishPath
        ? location.pathname.replace(/^\/en(?=\/|$)/, '') || '/'
        : location.pathname
      const localizedSection = /^\/(?:blog|notes|projects|about|contact|search|tags|archives)(?:\/|$)/
      const supportsLocale = pathWithoutLocale === '/' || localizedSection.test(pathWithoutLocale)
      const targetPath =
        supportsLocale && savedLocale === 'en-US' && !isEnglishPath
          ? `/en${pathWithoutLocale === '/' ? '' : pathWithoutLocale}`
          : supportsLocale && savedLocale === 'zh-CN' && isEnglishPath
            ? pathWithoutLocale
            : null
      const localeRedirect = targetPath
        ? `${targetPath}${location.search}${location.hash}`
        : null

      if (localeRedirect) {
        location.replace(localeRedirect)
      } else {
        const recordCurrentPage = () => {
          const currentPath = `${location.pathname}${location.search}`
          const storedCurrent = sessionStorage.getItem('site-navigation-current')

          if (storedCurrent && storedCurrent !== currentPath) {
            sessionStorage.setItem('site-navigation-previous', storedCurrent)
          } else if (!storedCurrent && document.referrer) {
            const referrer = new URL(document.referrer)
            const referrerPath = `${referrer.pathname}${referrer.search}`
            if (referrer.origin === location.origin && referrerPath !== currentPath) {
              sessionStorage.setItem('site-navigation-previous', referrerPath)
            }
          }

          sessionStorage.setItem('site-navigation-current', currentPath)
        }

        recordCurrentPage()
        window.addEventListener('pageshow', (event) => {
          if (event.persisted) recordCurrentPage()
        })
      }
    </script>
  </head>

  <body class='flex justify-center bg-background text-foreground' {...props}>
    {
      highlightColor && (
        <div
          id='highlight-gradient'
          class='pointer-events-none absolute start-0 top-0 z-0 h-screen w-full opacity-25'
          style={`background-image:linear-gradient(${highlightColor},transparent)`}
        />
      )
    }
    <div
      id='main-container'
      class='w-full max-w-[70rem] min-h-[100dvh] flex flex-col justify-between'
    >
      <SiteHeader {locale} />
      <div
        class='flex-1 w-full'
        data-pagefind-body={searchIndexable ? true : undefined}
        data-pagefind-filter={searchIndexable ? `section:${searchSection}` : undefined}
      >
        <slot />
      </div>
      <SiteFooter {locale} />
    </div>

    {/* Set highlight color */}
    <style define:vars={{ highlightColor }}>
      :global(.highlight) {
        --highlight-fg: color-mix(
          in srgb,
          var(--highlightColor) 40%,
          hsl(var(--foreground)/var(--un-text-opacity, 1))
        );
        color: var(--highlight-fg, hsl(var(--primary) / var(--un-text-opacity))) !important;
      }
      :global(.highlight-bg) {
        background-color: var(
          --highlightColor,
          hsl(var(--primary) / var(--un-text-opacity))
        ) !important;
      }

      /* Extend safe area for some special screens
       * https://developer.mozilla.org/en-US/docs/Web/CSS/Reference/Values/env
       * https://webkit.org/blog/7929/designing-websites-for-iphone-x/
       */
      #main-container {
        padding-top: env(safe-area-inset-top);
        padding-left: calc(1rem + env(safe-area-inset-left));
        padding-right: calc(1rem + env(safe-area-inset-right));
      }
      @media (min-width: 640px) {
        #main-container {
          padding-left: calc(1.75rem + env(safe-area-inset-left));
          padding-right: calc(1.75rem + env(safe-area-inset-right));
        }
      }
      @media (min-width: 1024px) {
        #main-container {
          padding-left: calc(2.5rem + env(safe-area-inset-left));
          padding-right: calc(2.5rem + env(safe-area-inset-right));
        }
      }
    </style>
  </body>
</html>
