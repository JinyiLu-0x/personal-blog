---
import { Icon } from 'astro-pure/user'
import type { SiteLocale } from '@/i18n/ui'

interface Props { locale?: SiteLocale }
const { locale = 'zh-CN' } = Astro.props
const isChinese = locale === 'zh-CN'
---

<footer class='mx-auto mb-5 mt-16 w-full'>
  <div class='flex items-center gap-y-3 border-t pt-5 text-muted-foreground max-sm:flex-col sm:justify-between'>
    <div class='flex items-center gap-x-4 gap-y-2 max-sm:flex-col'>
      <span>© {new Date().getFullYear()} Moz</span>
      <a class='font-medium text-foreground underline' href='/terms'>{isChinese ? '网站政策' : 'Site Policy'}</a>
      <span>
        {isChinese ? '基于' : 'Powered by'}
        <a class='mx-1 font-medium text-foreground underline' href='https://github.com/withastro/astro' target='_blank'>Astro</a>
        &
        <a class='ms-1 font-medium text-foreground underline' href='https://github.com/cworld1/astro-theme-pure' target='_blank'>Pure</a>
      </span>
    </div>
    <div class='flex items-center gap-x-4'>
      <a href='/rss.xml' aria-label='RSS'><Icon name='rss' /></a>
    </div>
  </div>
</footer>
