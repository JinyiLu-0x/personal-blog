---
/**
 * Astro Theme Pure Header (Apache-2.0), kept intentionally close to upstream.
 * Local changes are limited to GitHub, an EN placeholder, and a two-state theme icon.
 */
import config from 'virtual:config'

import { Icon } from 'astro-pure/user'
import { profile } from '@/site-config'
import { getUi, localizedPath, type SiteLocale } from '@/i18n/ui'

interface Props { locale?: SiteLocale }
const { locale = 'zh-CN' } = Astro.props
const ui = getUi(locale)
const isEnglish = locale === 'en-US'
const languageHref = isEnglish
  ? Astro.url.pathname.replace(/^\/en(?=\/|$)/, '') || '/'
  : `/en${Astro.url.pathname === '/' ? '' : Astro.url.pathname}`
const menu = [
  { title: ui.nav.blog, link: localizedPath('/blog', locale) },
  { title: ui.nav.notes, link: localizedPath('/notes', locale) },
  { title: ui.nav.projects, link: localizedPath('/projects', locale) },
  { title: ui.nav.about, link: localizedPath('/about', locale) },
  { title: ui.nav.contact, link: localizedPath('/contact', locale) }
]
---

<header-component
  class='group sticky top-4 z-50 max-md:z-30 mb-12 flex items-center justify-between rounded-xl border border-transparent max-sm:py-1 sm:rounded-2xl'
>
  <a
    class='z-30 text-xl font-medium group-[.not-top]:ms-2 sm:group-[.not-top]:ms-3'
    style='transition:margin-inline 0.3s'
    href={localizedPath('/', locale)}
    aria-label='Brand'>{config.title}</a
  >

  <div class='flex items-center gap-x-0.5'>
    <div
      id='headerExpandContent'
      class='end-0 start-0 top-12 grid border border-transparent group-[.not-top]:rounded-xl group-[.expanded]:opacity-100 dark:group-[.expanded.not-top]:bg-muted max-sm:absolute max-sm:opacity-0 max-sm:group-[.not-top]:border-border max-sm:group-[.expanded.not-top]:bg-background max-sm:group-[.not-top]:px-4 max-sm:group-[.not-top]:py-2 sm:grid-rows-1'
    >
      <div class='flex flex-col items-center justify-center overflow-hidden sm:flex-row'>
        {
          menu.map((item) => (
            <a
              href={item.link}
              class='w-full flex-none grow py-2 text-right font-medium transition-none hover:text-primary sm:w-fit sm:px-3'
              aria-label='Nav menu item'
              data-astro-prefetch
            >
              {item.title}
            </a>
          ))
        }
        <div class='flex w-full grow flex-row justify-end gap-0 sm:w-fit'>
          <a
            class='header-action box-content flex size-5 items-center justify-center rounded-lg p-2 text-muted-foreground hover:text-primary'
            href={localizedPath('/search', locale)}
            title={ui.common.search}
          >
            <span class='sr-only'>{ui.common.search}</span>
            <Icon name='search' class='size-5' />
          </a>
          <a
            class='header-action box-content flex size-5 items-center justify-center rounded-lg p-2 text-muted-foreground hover:text-primary'
            href={profile.github}
            target='_blank'
            rel='me noreferrer'
            title='GitHub'
          >
            <span class='sr-only'>GitHub</span>
            <Icon name='github' class='size-5' />
          </a>
          <a
            class='header-action box-content flex size-5 items-center justify-center rounded-lg p-2 text-sm font-medium text-muted-foreground hover:text-primary'
            title={isEnglish ? 'Switch to Chinese' : '切换到英文'}
            aria-label={isEnglish ? 'Switch to Chinese' : '切换到英文'}
            href={languageHref}
            data-language-switch={isEnglish ? 'zh-CN' : 'en-US'}
          >
            <span>{isEnglish ? 'ZH' : 'EN'}</span>
          </a>
        </div>
      </div>
    </div>

    <div class='z-30 flex gap-0' style='transition:gap 0.3s'>
      <button
        id='toggleDarkMode'
        class='header-action group/dark box-content size-5 rounded-lg p-2 text-muted-foreground hover:text-primary'
        type='button'
        title={ui.common.theme}
        data-dark-label={ui.common.darkTheme}
        data-light-label={ui.common.lightTheme}
      >
        <span class='sr-only'>{ui.common.theme}</span>
        <Icon class='light size-5 group-hover/dark:text-primary' name='sun' />
        <Icon class='dark hidden size-5 group-hover/dark:text-primary' name='moon' />
      </button>
      <button
        id='toggleMenu'
        class='header-action box-content size-5 rounded-lg p-2 text-muted-foreground hover:text-primary sm:hidden'
        type='button'
        title={ui.common.menu}
      >
        <span class='sr-only'>{ui.common.menu}</span>
        <Icon class='size-5' name='menu' />
      </button>
    </div>
  </div>
</header-component>

<script is:inline>
  const toggleDarkModeElement = document.getElementById('toggleDarkMode')
  if (toggleDarkModeElement) {
    const savedTheme = localStorage.getItem('theme')
    const dark =
      savedTheme === 'dark' ||
      ((!savedTheme || savedTheme === 'system') &&
        window.matchMedia('(prefers-color-scheme: dark)').matches)
    toggleDarkModeElement.dataset.theme = dark ? 'dark' : 'light'
  }
</script>
<script is:inline>
  document.querySelector('[data-language-switch]')?.addEventListener('click', (event) => {
    const target = event.currentTarget
    if (target instanceof HTMLElement) {
      localStorage.setItem('locale', target.dataset.languageSwitch || 'en-US')
    }
  })
</script>
<script>
  function applyTheme(theme: 'light' | 'dark') {
    localStorage.setItem('theme', theme)
    document.documentElement.classList.toggle('dark', theme === 'dark')
    document
      .querySelector('meta[name="theme-color"]')
      ?.setAttribute('content', theme === 'dark' ? '#0B0B10' : '#FCFCFD')
  }

  function showThemeToast(message: string) {
    document.dispatchEvent(new CustomEvent('toast', { detail: { message } }))
  }

  class HeaderComponent extends HTMLElement {
    connectedCallback() {
      let preScrollY = window.scrollY
      this.classList.toggle('not-top', preScrollY > 20)
      window.addEventListener('scroll', () => {
        this.classList.toggle('not-top', window.scrollY > 20)
        this.dataset.show = (window.scrollY < 350 || window.scrollY < preScrollY).toString()
        preScrollY = window.scrollY
      })

      const darkModeBtn = this.querySelector('#toggleDarkMode') as HTMLElement
      darkModeBtn.addEventListener('click', () => {
        const nextTheme = document.documentElement.classList.contains('dark') ? 'light' : 'dark'
        applyTheme(nextTheme)
        darkModeBtn.dataset.theme = nextTheme
        showThemeToast(
          nextTheme === 'dark'
            ? (darkModeBtn.dataset.darkLabel ?? 'Dark theme')
            : (darkModeBtn.dataset.lightLabel ?? 'Light theme')
        )
      })

      this.querySelector('#toggleMenu')?.addEventListener('click', () => {
        this.classList.toggle('expanded')
      })
    }
  }

  if (!customElements.get('header-component')) {
    customElements.define('header-component', HeaderComponent)
  }
</script>

<style>
  header-component {
    transition:
      padding 0.3s,
      transform 0.3s,
      margin-inline 0.3s,
      border 0.15s,
      background-color 0.15s;

    &.not-top {
      border-color: rgba(255, 255, 255, 0.66);
      background-color: rgba(255, 255, 255, 0.58);
      padding-left: 0.375rem;
      padding-right: 0.375rem;
      -webkit-backdrop-filter: blur(20px) saturate(125%) brightness(104%);
      backdrop-filter: blur(20px) saturate(125%) brightness(104%);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.92),
        inset 0 -1px 0 rgba(53, 61, 66, 0.08),
        0 12px 30px -22px rgba(34, 48, 58, 0.52);
    }
    &[data-show='false']:not(.expanded) {
      transform: translateY(-5rem);
    }
  }
  .header-action {
    background: transparent;
    transition:
      color 0.18s ease,
      background-color 0.18s ease,
      transform 0.18s ease;
  }
  .header-action:hover {
    background-color: hsl(var(--muted) / 0.72);
    transform: translateY(-1px);
  }
  @media (prefers-reduced-motion: reduce) {
    .header-action:hover {
      transform: none;
    }
  }
  @media (min-width: 800px) {
    header-component.not-top {
      margin-inline: 8%;
    }
  }
  :global(.dark) header-component.not-top {
    border-color: rgba(255, 255, 255, 0.13);
    background-color: hsl(var(--muted) / 0.72);
  }

  @media (max-width: 640px) {
    #headerExpandContent {
      grid-template-rows: 0fr;
      transition:
        opacity 0.3s,
        padding 0.3s,
        border-color 0.15s,
        grid-template-rows 0.3s;
    }
    .expanded #headerExpandContent {
      grid-template-rows: 1fr;
      border-color: rgba(255, 255, 255, 0.64);
      background-color: rgba(255, 255, 255, 0.62);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.9),
        inset 0 -1px 0 rgba(54, 62, 67, 0.08),
        0 18px 34px -24px rgba(34, 48, 58, 0.5);
      -webkit-backdrop-filter: blur(22px) saturate(125%) brightness(104%);
      backdrop-filter: blur(22px) saturate(125%) brightness(104%);
    }
    .expanded.not-top #headerExpandContent {
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.9),
        inset 0 -1px 0 rgba(54, 62, 67, 0.08),
        0 18px 34px -24px rgba(34, 48, 58, 0.5);
    }

    header-component #headerExpandContent::after {
      box-sizing: content-box;
      content: '';
      position: absolute;
      inset-inline: calc(-1rem - 1px);
      bottom: 0;
      top: -5rem;
      z-index: -1;
      transition: 0.3s;
      visibility: hidden;
      opacity: 0;
      border-bottom: 1px solid transparent;
    }
    header-component:not(.not-top) #headerExpandContent::after {
      visibility: visible;
      bottom: -1rem;
      opacity: 1;
      background-color: rgba(255, 255, 255, 0.46);
      border-bottom-color: rgba(255, 255, 255, 0.58);
      -webkit-backdrop-filter: blur(22px) saturate(125%);
      backdrop-filter: blur(22px) saturate(125%);
    }
    :global(.dark) .expanded #headerExpandContent,
    :global(.dark) header-component:not(.not-top) #headerExpandContent::after {
      border-color: rgba(255, 255, 255, 0.12);
      background-color: hsl(var(--muted) / 0.76);
    }
  }

  #toggleDarkMode[data-theme='dark'] {
    & .light {
      display: none;
    }
    & .dark {
      display: block;
    }
  }
</style>
