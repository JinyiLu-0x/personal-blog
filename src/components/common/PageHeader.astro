---
import { cn } from 'astro-pure/utils'

interface Props {
  title: string
  subtitle?: string
  eyebrow?: string
  class?: string
  id?: string
}

const { title, subtitle, eyebrow, class: className, ...props } = Astro.props
---

<header class={cn('border-b border-border/80 pb-6', className)} {...props}>
  {eyebrow && <p class='mb-2 font-mono text-sm text-primary'>{eyebrow}</p>}
  <h1 class='text-3xl font-medium tracking-tight'>{title}</h1>
  {subtitle && <p class='mt-3 max-w-2xl leading-relaxed text-muted-foreground'>{subtitle}</p>}
</header>
