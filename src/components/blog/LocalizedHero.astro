---
import { Image } from 'astro:assets'
import type { InferEntrySchema } from 'astro:content'
import { Icon } from 'astro-pure/user'
import LocalizedDate from '@/components/common/LocalizedDate.astro'
import { formatReadingTime, formatTag, localizedPath, type SiteLocale } from '@/i18n/ui'

interface Props {
  data: InferEntrySchema<'blog'>
  remarkPluginFrontmatter: Record<string, unknown>
  locale: SiteLocale
}
const { data, remarkPluginFrontmatter, locale } = Astro.props
const { title, description, draft, heroImage, publishDate, updatedDate, tags, language } = data
const isChinese = locale === 'zh-CN'
const shortDate = { year: 'numeric', month: 'short', day: 'numeric' } as const
---

{heroImage && <Image alt={heroImage.alt || title} class='mb-6 h-auto w-full max-w-[65ch] rounded-2xl object-contain' loading='eager' {...heroImage} />}
{draft && <span class='text-red-500'>{isChinese ? '（草稿）' : '(Draft)'}</span>}
<div class='article-info max-lg:mx-auto'>
  <div class='flex flex-wrap gap-x-4 gap-y-2 text-xs leading-6 text-muted-foreground'>
    <div class='flex items-center gap-1'>
      <Icon name='calendar' class='size-5' />
      <LocalizedDate date={publishDate} {locale} options={shortDate} class='font-sans' />
      {updatedDate && <span> / {isChinese ? '更新于' : 'Updated'} <LocalizedDate date={updatedDate} {locale} options={shortDate} class='font-sans' /></span>}
    </div>
    <div class='flex items-center gap-1'><Icon name='time' class='size-5' />{formatReadingTime(remarkPluginFrontmatter.minutesRead, locale)}</div>
    {language && <span class='flex items-center gap-1'><Icon name='earth' class='size-5' />{language}</span>}
    {!!tags.filter(Boolean).length && <span class='flex items-center gap-1'><Icon name='hashtag' class='size-5' />{tags.filter(Boolean).map((tag, index, visibleTags) => <span><a class='hover:underline' href={localizedPath(`/tags/${tag}`, locale)}>{formatTag(tag, locale)}</a>{index < visibleTags.length - 1 && ' / '}</span>)}</span>}
  </div>
  <h1 class='mt-4 text-2xl font-medium sm:mb-2 sm:mt-6 sm:text-3xl'>{title}</h1>
  <blockquote class='mt-3 text-sm italic text-muted-foreground'><q>{description}</q></blockquote>
</div>
<div class='mt-4 w-1/2 border-t max-md:mx-auto sm:mt-6 sm:w-1/3'></div>
