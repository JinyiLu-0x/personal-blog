---
import { render } from 'astro:content'
import { Icon } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'
import type { BlogEntry } from '@/utils/content'
import { getCanonicalId } from '@/utils/content'
import { formatReadingTime, formatTag, localizedPath, type SiteLocale } from '@/i18n/ui'
import LocalizedDate from '@/components/common/LocalizedDate.astro'

interface Props {
  post: BlogEntry
  locale?: SiteLocale
  detailed?: boolean
  class?: string
}

const { post, locale = 'zh-CN', detailed = false, class: className } = Astro.props
const { data } = post
const { remarkPluginFrontmatter } = await render(post)
const postDate = data.updatedDate ?? data.publishDate
const href = localizedPath(`/blog/${getCanonicalId(post)}`, locale)
---

<li class={cn('post-preview', className)}>
  <a
    class={cn(
      'group relative block w-full rounded-2xl border bg-background px-5 py-2.5 transition-colors ease-in-out hover:bg-muted hover:text-primary',
      detailed && 'max-sm:px-4 sm:py-5'
    )}
    {href}
    data-astro-prefetch
  >
    <div class={cn('relative flex flex-col gap-1', !detailed && 'sm:flex-row sm:items-center')}>
      <LocalizedDate class='min-w-[95px] text-xs' date={postDate} {locale} />
      <div class='flex flex-grow justify-between'>
        <div class={detailed ? 'font-medium' : undefined}>{data.title}</div>
        <span aria-hidden='true' class='text-muted-foreground transition-transform group-hover:translate-x-1'>→</span>
      </div>
      {
        detailed && (
          <>
            <p class='line-clamp-2 text-sm text-muted-foreground sm:line-clamp-3'>{data.description}</p>
            <div class='flex items-center gap-2 py-2 text-sm italic leading-4 text-muted-foreground'>
              <span class='flex items-center gap-1'><Icon name='time' class='size-4' />{formatReadingTime(remarkPluginFrontmatter.minutesRead, locale)}</span>
              {data.language && <span class='flex items-center gap-1'><Icon name='earth' class='size-4' />{data.language}</span>}
            </div>
            {data.tags.filter(Boolean).length > 0 && (
              <ul class='mt-1 flex flex-wrap gap-2'>
                {data.tags.filter(Boolean).map((tag) => (
                  <li class='rounded-xl border bg-muted px-2 py-1 text-xs text-muted-foreground'>
                    #{formatTag(tag, locale)}
                  </li>
                ))}
              </ul>
            )}
          </>
        )
      }
    </div>
  </a>
</li>
