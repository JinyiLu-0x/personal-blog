---
import type { SiteLocale } from '@/i18n/ui'

interface Props {
  locale?: SiteLocale
  class?: string
}

const { locale = 'zh-CN', class: className = 'mt-6' } = Astro.props
const isChinese = locale === 'zh-CN'
---

<section id='comments' class:list={[className, 'rounded-2xl border border-border/90 bg-card/45 p-5']}>
  <p class='font-mono text-xs uppercase tracking-[0.16em] text-primary'>
    {isChinese ? '评论' : 'Comments'}
  </p>
  <h2 class='mt-2 text-base font-medium text-foreground'>
    {isChinese ? '评论区已预留' : 'Discussion space reserved'}
  </h2>
  <p class='mt-1 text-sm text-muted-foreground'>
    {
      isChinese
        ? '连接自有评论服务后，这里会显示留言输入框与公开讨论内容。当前不会收集评论数据。'
        : 'Once a private comment service is connected, the comment form and public discussion will appear here. No comment data is currently collected.'
    }
  </p>
</section>
