---
import type { SiteLocale } from '@/i18n/ui'
import type { TopicCloudItem } from '@/utils/topic-cloud'

interface Props {
  topics: TopicCloudItem[]
  locale: SiteLocale
}

const { topics, locale } = Astro.props
const isChinese = locale === 'zh-CN'
const colorClasses = [
  'fill-primary',
  'fill-sky-700 dark:fill-sky-300',
  'fill-slate-700 dark:fill-slate-200',
  'fill-cyan-700 dark:fill-cyan-300',
  'fill-blue-600 dark:fill-blue-300',
  'fill-foreground/70'
]
---

{
  topics.length > 0 && (
    <aside
      class='relative overflow-hidden rounded-2xl border border-white/80 bg-white/45 p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.95),0_16px_40px_-32px_rgba(51,92,119,0.85)] backdrop-blur-xl dark:border-white/10 dark:bg-white/[0.045] sm:p-4'
      aria-label={isChinese ? '根据网站正文生成的词云' : 'Word cloud generated from website content'}
    >
      <h2 class='sr-only'>{isChinese ? '我经常思考的词汇' : 'Words I often think about'}</h2>
      <svg
        class='block h-auto w-full'
        viewBox='0 0 1000 420'
        role='img'
        aria-label={isChinese ? '博客、笔记和项目正文高频词云' : 'Frequent words from blog, notes, and project content'}
      >
        {topics.map((topic) => (
          <text
            x={topic.x}
            y={topic.y}
            text-anchor='middle'
            dominant-baseline='central'
            transform={`rotate(${topic.rotate} ${topic.x} ${topic.y})`}
            class:list={[
              'select-none font-mono transition-opacity duration-200 hover:opacity-100 motion-reduce:transition-none',
              colorClasses[topic.color]
            ]}
            style={`font-size:${topic.size}px;opacity:${Math.min(0.96, 0.68 + topic.size / 220).toFixed(2)};font-weight:${topic.size > 42 ? 650 : topic.size > 27 ? 560 : 470}`}
          >
            <title>{`${topic.word} · ${topic.count}`}</title>
            {topic.word}
          </text>
        ))}
      </svg>
    </aside>
  )
}
