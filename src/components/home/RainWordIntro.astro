---
import type { SiteLocale } from '@/i18n/ui'
import type { TopicCloudItem } from '@/utils/topic-cloud'

interface Props {
  topics: TopicCloudItem[]
  locale: SiteLocale
}

const { locale } = Astro.props
const isChinese = locale === 'zh-CN'
// Opening animation uses a single carefully spaced English layout for both
// locales. The homepage's real word cloud still uses the generated bilingual
// topic data; this intro keeps the visual stable while echoing the same ideas.
const introTopics = [
