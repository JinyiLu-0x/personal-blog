---
type Props = {
  title: string
  skills: readonly string[]
}

const { title, skills } = Astro.props
---

<div class='grid gap-y-2 sm:grid-cols-[8rem_minmax(0,1fr)] sm:gap-x-4 sm:gap-y-0'>
  <h3 class='font-medium'>{title}</h3>
  <div class='flex flex-row flex-wrap gap-1.5'>
    {
      skills.map((skill: string) => (
        <span class='inline-flex items-center rounded-lg border bg-muted px-2 py-0.5 text-sm leading-5 text-muted-foreground'>
          {skill}
        </span>
      ))
    }
  </div>
</div>
