---
import { cn } from 'astro-pure/utils'
import Pageview from '@/components/waline/Pageview.astro'
import { getWalinePath } from '@/utils/waline'

interface Props {
  view?: boolean
  comment?: boolean
  class?: string
}

const { view, comment, class: className, ...props } = Astro.props

const path = getWalinePath(Astro.url.pathname)
---

<div class={cn('text-base text-sm text-muted-foreground', className)} {...props}>
  <span class='waline-pageview-count' data-path={path}>0</span> views
  {
    comment && (
      <>
        {' | '}
        <a href='#waline'>
          <span class='waline-comment-count' data-path={path}>0</span> comments
        </a>
      </>
    )
  }
</div>

{(view || comment) && <Pageview />}
