---
// https://waline.js.org/en/guide/features/pageview.html#use-alone
import config from '@/site-config'
import { WALINE_PATH_PREFIX } from '@/utils/waline'
---

<script
  is:inline
  type='module'
  data-astro-rerun
  define:vars={{ walineServer: config.integ.waline.server, walinePathPrefix: WALINE_PATH_PREFIX }}
>
  const MIN_ACTIVE_SECONDS = 8
  const MIN_READ_PROGRESS = 0.8
  const VIEW_DEDUP_WINDOW = 24 * 60 * 60 * 1000

  async function setupEngagedPageview() {
    const elements = [...document.querySelectorAll('.waline-pageview-count')]
    if (!elements.length || !walineServer) return

    const path = `${walinePathPrefix}${window.location.pathname}`
    const apiBase = `${walineServer.replace(/\/$/, '')}/api/article`
    const storageKey = `moz-pageview:${path}`
    let activeSeconds = 0
    let submitted = false

    const renderCount = (value) => {
      const count = Number.isFinite(Number(value)) ? Number(value) : 0
      elements.forEach((element) => {
        element.textContent = String(count)
      })
    }

    const fetchCount = async () => {
      const params = new URLSearchParams({ path, type: 'time', lang: document.documentElement.lang })
      const response = await fetch(`${apiBase}?${params}`)
      if (!response.ok) throw new Error(`Pageview request failed: ${response.status}`)
      const payload = await response.json()
      renderCount(payload?.data?.[0]?.time ?? 0)
    }

    const getLastView = () => {
      try {
        return Number(localStorage.getItem(storageKey) ?? 0)
      } catch {
        return 0
      }
    }

    const rememberView = () => {
      try {
        localStorage.setItem(storageKey, String(Date.now()))
      } catch {
        // Counting still works when storage is unavailable; only deduplication is skipped.
      }
    }

    const getReadProgress = () => {
      const pageHeight = document.documentElement.scrollHeight
      if (pageHeight <= window.innerHeight * 1.25) return 1
      return Math.min(1, (window.scrollY + window.innerHeight) / pageHeight)
    }

    const submitView = async () => {
      if (submitted) return
      submitted = true

      try {
        const response = await fetch(`${apiBase}?lang=${encodeURIComponent(document.documentElement.lang)}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ path, type: 'time', action: 'inc' }),
          keepalive: true
        })
        if (!response.ok) throw new Error(`Pageview update failed: ${response.status}`)
        rememberView()
        await fetchCount()
      } catch (error) {
        submitted = false
        console.error('Failed to update Waline pageview:', error)
      }
    }

    const checkEngagement = () => {
      if (
        !submitted &&
        activeSeconds >= MIN_ACTIVE_SECONDS &&
        getReadProgress() >= MIN_READ_PROGRESS
      ) {
        void submitView()
      }
    }

    try {
      await fetchCount()
    } catch (error) {
      console.error('Failed to load Waline pageview:', error)
    }

    if (Date.now() - getLastView() < VIEW_DEDUP_WINDOW) {
      submitted = true
      return
    }

    const activeTimer = window.setInterval(() => {
      if (document.visibilityState === 'visible' && document.hasFocus()) {
        activeSeconds += 1
        checkEngagement()
      }
    }, 1000)

    window.addEventListener('scroll', checkEngagement, { passive: true })
    window.addEventListener('pagehide', () => window.clearInterval(activeTimer), { once: true })
  }

  setupEngagedPageview()
</script>
