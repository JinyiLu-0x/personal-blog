---
import { type ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

import { Svg } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'

interface Props {
  class?: string
  title: string
  tools: {
    name: string
    description: string
    href: string
    icon?: Promise<typeof import('*.svg?raw')> | ImageMetadata | string
    darkIcon?: Promise<typeof import('*.svg?raw')> | ImageMetadata | string
  }[]
}

const { class: className, title, tools, ...props } = Astro.props

function isImageMetadata(obj: unknown): obj is ImageMetadata {
  return typeof obj === 'object' && obj !== null && 'src' in obj
}

function isRemoteIcon(icon: unknown): icon is string {
  return typeof icon === 'string'
}
---

<div
  class={cn('not-prose flex flex-col rounded-2xl border border-border/80 bg-card/55 py-4 px-3 gap-y-3 sm:gap-y-4', className)}
  {...props}
>
  <div class='m-0 px-2 text-lg font-medium'>{title}</div>
  <div class='grid grid-cols-1 gap-x-2 gap-y-2 sm:grid-cols-2'>
    {
      tools.map((tool) => (
        <a
          class='group relative block text-sm leading-normal no-underline'
          id={tool.name}
          href={tool.href}
          target='_blank'
          rel='noreferrer'
          aria-label={`${tool.name} — ${tool.description}`}
        >
          <div class='flex min-h-16 items-center gap-x-3 rounded-xl border border-border/55 bg-background/70 px-3 py-2 transition-all duration-200 hover:-translate-y-0.5 hover:border-primary/35 hover:bg-muted/70 hover:shadow-sm motion-reduce:transform-none'>
            <span class='block shrink-0 rounded-lg transition-transform group-hover:scale-105 motion-reduce:transform-none'>
              {tool.darkIcon && tool.icon ? (
                <>
                  {isRemoteIcon(tool.icon) ? (
                    <div class='size-10 rounded-lg bg-muted p-2 dark:hidden'>
                      <img src={tool.icon} alt='' class='h-full w-full object-contain' loading='lazy' />
                    </div>
                  ) : isImageMetadata(tool.icon) ? (
                    <div class='size-10 rounded-lg bg-muted p-2 dark:hidden'>
                      <Image src={tool.icon} alt='' class='h-full w-full object-contain' />
                    </div>
                  ) : (
                    <Svg src={tool.icon} class='size-10 rounded-lg bg-muted fill-foreground p-2 dark:hidden' />
                  )}

                  {isRemoteIcon(tool.darkIcon) ? (
                    <div class='size-10 rounded-lg bg-muted p-2 hidden dark:block'>
                      <img src={tool.darkIcon} alt='' class='h-full w-full object-contain' loading='lazy' />
                    </div>
                  ) : isImageMetadata(tool.darkIcon) ? (
                    <div class='size-10 rounded-lg bg-muted p-2 hidden dark:block'>
                      <Image src={tool.darkIcon} alt='' class='h-full w-full object-contain' />
                    </div>
                  ) : (
                    <Svg src={tool.darkIcon} class='size-10 rounded-lg bg-muted fill-foreground p-2 hidden dark:block' />
                  )}
                </>
              ) : tool.icon ? (
                <>
                  {isRemoteIcon(tool.icon) ? (
                    <div class='size-10 rounded-lg bg-muted p-2'>
                      <img src={tool.icon} alt='' class='h-full w-full object-contain' loading='lazy' />
                    </div>
                  ) : isImageMetadata(tool.icon) ? (
                    <div class='size-10 rounded-lg bg-muted p-2'>
                      <Image src={tool.icon} alt='' class='h-full w-full object-contain' />
                    </div>
                  ) : (
                    <Svg src={tool.icon} class='size-10 rounded-lg bg-muted fill-foreground p-2' />
                  )}
                </>
              ) : (
                <div class='flex size-10 items-center justify-center rounded-lg border border-border/70 bg-muted font-mono text-sm font-medium text-primary'>
                  {tool.name
                    .split(/\s+/)
                    .map((word) => word[0])
                    .join('')
                    .slice(0, 2)
                    .toUpperCase()}
                </div>
              )}
            </span>
            <div class='z-20 min-w-0 flex flex-1 flex-col'>
              <div class='font-medium text-foreground'>{tool.name}</div>
              <div class='font-normal'>{tool.description}</div>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</div>
