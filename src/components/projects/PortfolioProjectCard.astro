---
import { Icon } from 'astro-pure/user'
import type { ProjectEntry } from '@/utils/content'
import { getCanonicalId } from '@/utils/content'
import { formatTag, localizedPath, type SiteLocale } from '@/i18n/ui'
import LocalizedDate from '@/components/common/LocalizedDate.astro'

interface Props {
  project: ProjectEntry
  compact?: boolean
  locale?: SiteLocale
}

const { project, compact = false, locale = 'zh-CN' } = Astro.props
const { data } = project

const statusLabelsZh = {
  building: '开发中',
  active: '进行中',
  maintained: '维护中',
  complete: '已完成',
  archived: '已归档',
  concept: '概念阶段'
} as const
const statusLabelsEn = { building: 'Building', active: 'Active', maintained: 'Maintained', complete: 'Complete', archived: 'Archived', concept: 'Concept' } as const
const statusLabels = locale === 'zh-CN' ? statusLabelsZh : statusLabelsEn
const href = localizedPath(`/projects/${getCanonicalId(project)}`, locale)
---

<article
  class='glass-surface glass-surface--grey flex h-full flex-col rounded-2xl border px-5 py-3 transition-all hover:-translate-y-0.5 hover:border-foreground/25 hover:shadow-sm motion-reduce:transform-none'
>
  <div class='mb-3 flex flex-wrap items-center gap-2 text-xs text-muted-foreground'>
    <span class='flex items-center gap-1 rounded-full border bg-muted px-2 py-1'>
      <span class='size-1.5 rounded-full bg-primary'></span>
      {statusLabels[data.status]}
    </span>
    <LocalizedDate date={data.updatedDate ?? data.publishDate} {locale} />
  </div>

  <h2 class:list={['font-medium', compact ? 'text-base' : 'text-xl']}>
    <a href={href} class='hover:text-primary' data-astro-prefetch>{data.title}</a>
  </h2>
  <p class:list={['mt-2 flex-1 text-muted-foreground', compact && 'line-clamp-2 text-sm']}>
    {data.description}
  </p>

  {
    !compact && (
      <p class='mt-3 text-sm'>
        <span class='text-muted-foreground'>{locale === 'zh-CN' ? '角色：' : 'Role: '}</span>{data.role}
      </p>
    )
  }

  <ul class='mt-4 flex flex-wrap gap-2' aria-label='Technology stack'>
    {
      data.techStack.map((technology) => (
        <li class='rounded-full bg-muted px-2.5 py-1 text-xs text-muted-foreground'>
          {technology}
        </li>
      ))
    }
  </ul>

  {
    !compact && data.tags.length > 0 && (
      <ul class='mt-3 flex flex-wrap gap-2' aria-label='Project tags'>
        {data.tags.filter(Boolean).map((tag) => (
          <li>
            <a
              href={`/tags/${encodeURIComponent(tag)}`}
              class='block rounded-full border px-2.5 py-1 text-xs text-muted-foreground transition-colors hover:bg-border hover:text-primary'
            >
              #{formatTag(tag, locale)}
            </a>
          </li>
        ))}
      </ul>
    )
  }

  <div class='mt-4 flex items-center justify-between gap-3 border-t pt-3'>
    <a href={href} class='text-sm font-medium transition-colors hover:text-primary'
      >{locale === 'zh-CN' ? '查看项目' : 'View project'} →</a
    >
    <div class='flex items-center gap-2'>
      {
        data.links.github && (
          <a
            href={data.links.github}
            target='_blank'
            rel='noreferrer'
            class='transition-colors hover:text-primary'
            aria-label={`${data.title} GitHub`}
          >
            <Icon name='github' class='size-5' />
          </a>
        )
      }
      {
        data.links.demo && (
          <a
            href={data.links.demo}
            target='_blank'
            rel='noreferrer'
            class='transition-colors hover:text-primary'
            aria-label={`${data.title} demo`}
          >
            <Icon name='earth' class='size-5' />
          </a>
        )
      }
    </div>
  </div>
</article>
