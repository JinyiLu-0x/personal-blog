---
import { Image } from 'astro:assets'
import { resume } from '@/data/resume'

import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import { getPublicNotes, getPublicProjects, getPublishedBlogPosts } from '@/utils/content'
import avatar from '@/assets/avatar.png'
import { profile } from '@/site-config'
import { getUi, localizedPath, type SiteLocale } from '@/i18n/ui'
import { getCanonicalId } from '@/utils/content'
import LocalizedPostPreview from '@/components/blog/LocalizedPostPreview.astro'
import TopicCloud from '@/components/home/TopicCloud.astro'
import EducationGlass from '@/components/home/EducationGlass.astro'
import RainWordIntro from '@/components/home/RainWordIntro.astro'
import { buildTopicCloud } from '@/utils/topic-cloud'

interface Props { locale?: SiteLocale }
const { locale = 'zh-CN' } = Astro.props

const [posts, projects, notes] = await Promise.all([
  getPublishedBlogPosts(locale),
  getPublicProjects(locale),
  getPublicNotes(locale)
])

const featuredProjects = projects.filter(({ data }) => data.featured).slice(0, 2)
const latestPosts = posts.slice(0, 5)
const latestNotes = notes.slice(0, 3)
const topicCloud = buildTopicCloud([...posts, ...projects, ...notes], locale)
const ui = getUi(locale)
const projectStatus = locale === 'zh-CN'
  ? { building: '开发中', active: '进行中', maintained: '维护中', complete: '已完成', archived: '已归档', concept: '概念阶段' }
  : { building: 'Building', active: 'Active', maintained: 'Maintained', complete: 'Complete', archived: 'Archived', concept: 'Concept' }
---

<PageLayout
  meta={{ title: ui.home.title, description: ui.home.description }}
  {locale}
  highlightColor='#659EB9'
>
  <RainWordIntro topics={topicCloud} {locale} />
  <main class='flex w-full flex-col items-center'>
    <section
      class='animate mb-10 flex flex-col items-center gap-y-5 text-center'
      id='content-header'
    >
      <div class='flex flex-col items-center gap-y-3'>
        <Image
          src={avatar}
          alt='Moz avatar'
          width={112}
          height={112}
          loading='eager'
          class='mb-2 size-28 rounded-full border border-border object-cover p-1'
        />
        <h1 class='text-3xl font-medium'>{profile.displayName}</h1>
        <p class='text-muted-foreground'>{ui.home.role}</p>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title={ui.home.location}>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label title='GitHub' as='a' href={profile.github} target='_blank' rel='me noreferrer'>
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
        <a
          href={localizedPath('/contact', locale)}
          class='glass-surface glass-surface--clear mt-2 flex flex-row items-center gap-x-3 rounded-full border px-4 py-2 text-sm no-underline transition-all hover:-translate-y-0.5 hover:shadow-md motion-reduce:transform-none'
          data-astro-prefetch
        >
          <span class='relative flex items-center justify-center' aria-hidden='true'>
            <span class='absolute size-2 animate-ping rounded-full border border-green-400 bg-green-400 opacity-75'></span>
            <span class='size-2 rounded-full bg-green-400'></span>
          </span>
          <span class='font-medium text-muted-foreground'>{ui.home.contactMe}</span>
        </a>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <TopicCloud topics={topicCloud} {locale} />

      <Section title={ui.home.about}>
        <p class='px-3.5 text-muted-foreground'>
          {ui.home.intro}
        </p>
        <EducationGlass {locale} />
        <Button title={ui.home.moreAbout} class='w-fit self-end' href={localizedPath('/about', locale)} variant='ahead' />
      </Section>

      {
        latestPosts.length > 0 && (
          <Section title={ui.home.blog}>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {latestPosts.map((post) => (
                <LocalizedPostPreview {post} {locale} />
              ))}
            </ul>
            <Button title={ui.home.morePosts} class='w-fit self-end' href={localizedPath('/blog', locale)} variant='ahead' />
          </Section>
        )
      }

      {
        latestNotes.length > 0 && (
          <Section title={ui.home.notes}>
            <div class='flex flex-col gap-y-3'>
              {latestNotes.map((note) => (
                <Card
                  as='a'
                  href={localizedPath(`/notes/${getCanonicalId(note)}`, locale)}
                  heading={note.data.title}
                  subheading={note.data.summary}
                  class='glass-surface glass-surface--grey transition-colors'
                />
              ))}
            </div>
            <Button title={ui.home.moreNotes} class='w-fit self-end' href={localizedPath('/notes', locale)} variant='ahead' />
          </Section>
        )
      }

      {
        featuredProjects.length > 0 && (
          <Section title={ui.home.projects}>
            <div class='flex flex-col gap-y-3'>
              {featuredProjects.map((project) => (
                <Card
                  as='a'
                  href={localizedPath(`/projects/${getCanonicalId(project)}`, locale)}
                  heading={project.data.title}
                  subheading={project.data.description}
                  date={`${project.data.role} · ${projectStatus[project.data.status]}`}
                  class='glass-surface glass-surface--grey transition-colors'
                />
              ))}
            </div>
            <Button title={ui.home.moreProjects} class='w-fit self-end' href={localizedPath('/projects', locale)} variant='ahead' />
          </Section>
        )
      }

      <Section title={ui.home.skills}>
        {resume.skills.map((group, index) => (
          <SkillLayout title={Object.values(ui.skills)[index] ?? group.title} skills={group.items} />
        ))}
      </Section>
    </div>
  </main>
</PageLayout>
