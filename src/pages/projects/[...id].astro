---
import type { CollectionEntry } from 'astro:content'
import ProjectDetailPage from '@/components/pages/projects/ProjectDetailPage.astro'
import { getCanonicalId, getPublicProjects } from '@/utils/content'

export const prerender = true

export async function getStaticPaths() {
  const projects = await getPublicProjects('zh-CN')
  return projects.map((project) => ({ params: { id: getCanonicalId(project) }, props: { project } }))
}

interface Props {
  project: CollectionEntry<'projects'>
}

const { project } = Astro.props
---

<ProjectDetailPage {project} />
