---
import type { CollectionEntry } from 'astro:content'
import ProjectDetail from '../../projects/[...id].astro'
import { getCanonicalId, getPublicProjects } from '@/utils/content'

export const prerender = true
export async function getStaticPaths() {
  const projects = await getPublicProjects('en-US')
  return projects.map((project) => ({ params: { id: getCanonicalId(project) }, props: { project } }))
}
interface Props { project: CollectionEntry<'projects'> }
const { project } = Astro.props
---

<ProjectDetail {project} />
