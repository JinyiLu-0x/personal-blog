---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { getUniqueTagsWithCount } from 'astro-pure/server'
import BlogPage from '../../blog/[...page].astro'
import { getPublishedBlogPosts } from '@/utils/content'
import config from '@/site-config'

export const prerender = true

export const getStaticPaths = (async ({ paginate }) => {
  const collections = await getPublishedBlogPosts('en-US')
  const uniqueTags = getUniqueTagsWithCount(collections).map(([tag]) => tag)
  return paginate(collections, {
    pageSize: config.content.blogPageSize,
    props: { uniqueTags, collectionsCount: collections.length }
  })
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'blog'>>
  uniqueTags: string[]
  collectionsCount: number
}
const { page, uniqueTags, collectionsCount } = Astro.props
---

<BlogPage {page} {uniqueTags} {collectionsCount} locale='en-US' />
