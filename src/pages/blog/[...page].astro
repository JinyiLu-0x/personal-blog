---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { Paginator } from 'astro-pure/components/pages'
import { getUniqueTagsWithCount } from 'astro-pure/server'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import PageHeader from '@/components/common/PageHeader.astro'
import { getPublishedBlogPosts } from '@/utils/content'
import config from '@/site-config'
import { formatTag, getUi, localizedPath, type SiteLocale } from '@/i18n/ui'
import SmartBackButton from '@/components/common/SmartBackButton.astro'
import LocalizedPostPreview from '@/components/blog/LocalizedPostPreview.astro'

export const prerender = true

export const getStaticPaths = (async ({ paginate }) => {
  const collections = await getPublishedBlogPosts('zh-CN')
  const uniqueTags = getUniqueTagsWithCount(collections).map(([tag]) => tag)
  const collectionsCount = collections.length
  return paginate(collections, {
    pageSize: config.content.blogPageSize,
    props: { uniqueTags, collectionsCount }
  })
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'blog'>>
  uniqueTags: string[]
  collectionsCount: number
  locale?: SiteLocale
}

const { page, uniqueTags, collectionsCount, locale = 'zh-CN' } = Astro.props
const ui = getUi(locale)
const isChinese = locale === 'zh-CN'

const meta = {
  description: ui.pages.blogSubtitle,
  title: ui.pages.blog
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: isChinese ? `← 上一页` : `← Previous`,
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: isChinese ? `下一页 →` : `Next →`,
      url: page.url.next
    }
  })
}
---

<PageLayout {meta} {locale}>
  <main class='mx-auto mt-6 w-full max-w-5xl lg:mt-10'>
    <SmartBackButton fallback={localizedPath('/', locale)} {locale} />
    <PageHeader
      title={ui.pages.blog}
      subtitle={meta.description}
      class='animate mb-8 mt-6 sm:mt-10'
      id='content-header'
    />
    {
      page.data.length === 0 ? (
        <p>{isChinese ? '暂时没有公开文章。' : 'No published posts yet.'}</p>
      ) : (
        <div class='grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
          <section aria-label='Blog posts list' class='animate' id='content'>
            {/* header */}
            <div class='mb-3 flex flex-col justify-between text-sm sm:mb-5 sm:flex-row'>
              <span class='text-muted-foreground'>
                {isChinese ? `第 ${page.currentPage} 页 · 当前 ${page.data.length} 篇，共 ${collectionsCount} 篇` : `Page ${page.currentPage} · ${page.data.length} of ${collectionsCount} posts`}
              </span>
              <a aria-label='View all blog by years' href={localizedPath('/archives', locale)} data-astro-prefetch>
                {isChinese ? '按年份查看全部文章' : 'View all posts by year'} →
              </a>
            </div>
            {/* posts */}
            <ul class='flex flex-col gap-y-4 text-start'>
              {page.data.map((post) => (
                <LocalizedPostPreview {post} {locale} detailed />
              ))}
            </ul>
            <Paginator {...paginationProps} />
          </section>

          {/* sidebar */}
          {!!uniqueTags.length && (
            <aside class='animate' id='sidebar'>
              <h2 class='mb-4 flex items-center text-lg font-medium'>
                <Icon name='tag-2' class='me-2' />
                {ui.common.tags}
              </h2>
              <ul class='text-bgColor flex flex-wrap gap-2'>
                {
                  // Only show top 50 tags in sidebar
                  uniqueTags.slice(0, 50).map((tag) => (
                    <li>
                      <Button title={formatTag(tag, locale)} href={localizedPath(`/tags/${tag}`, locale)} variant='pill' />
                    </li>
                  ))
                }
              </ul>
              <span class='mt-4 block sm:text-end'>
                <a aria-label='View all blog categories' href={localizedPath('/tags', locale)} data-astro-prefetch>
                  {ui.common.viewAll} →
                </a>
              </span>
            </aside>
          )}
        </div>
      )
    }
  </main>
</PageLayout>
