---
import type { CollectionEntry } from 'astro:content'
import BlogDetailPage from '@/components/pages/blog/BlogDetailPage.astro'
import { getCanonicalId, getPublishedBlogPosts } from '@/utils/content'

export const prerender = true

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts('zh-CN')
  return posts.map((post) => ({
    params: { id: getCanonicalId(post) },
    props: { post, posts }
  }))
}

interface Props {
  post: CollectionEntry<'blog'>
  posts: CollectionEntry<'blog'>[]
}

const { post, posts } = Astro.props
---

<BlogDetailPage {post} {posts} />
